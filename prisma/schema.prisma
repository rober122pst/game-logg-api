// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Platform {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  icon       String?
  gameId     String[]     @db.ObjectId
  games      Game[]       @relation(fields: [gameId], references: [id])
  userGame   UserGame[]   @relation(fields: [userGameId], references: [id])
  userGameId String[]     @db.ObjectId
  beatEvents BeatEvents[]

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
}

model Genre {
  id   String  @id @default(auto()) @map("_id") @db.ObjectId
  name String
  icon String?

  gameIds String[] @db.ObjectId
  games   Game[]   @relation(fields: [gameIds], references: [id])

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
}

type ExternalIds {
  steamId String?
  rawg    String?
  igdb    String?
}

enum Critic {
  IGN
  Metacritic
  OpenCritic
}

type Rating {
  name    Critic
  score   Int?
  iconUrl String?
  link    String?
}

model Game {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  slug           String       @unique
  title          String
  platformIds    String[]     @db.ObjectId
  platforms      Platform[]   @relation(fields: [platformIds], references: [id])
  releaseDate    DateTime?
  genreIds       String[]     @db.ObjectId
  genres         Genre[]      @relation(fields: [genreIds], references: [id])
  coverUrl       String?
  bannerUrl      String?
  Screenshots    String[]
  description    String?
  externalIds    ExternalIds?
  preferedSource String?      @default("rawg")
  ratings        Rating[]
  createdAt      DateTime     @default(now())
  updateAt       DateTime     @updatedAt
  userGames      UserGame[]
}

enum Role {
  USER
  ADMIN
}

enum LinkType {
  DISCORD
  INSTAGRAM
  STEAM
  SPOTIFY
  YOUTUBE
}

type Link {
  name    LinkType
  url     String
  iconUrl String?
}

// Coisas do usuario

enum FollowStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Follow {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  followerId  String @db.ObjectId
  followingId String @db.ObjectId

  follower  Profile @relation("following", fields: [followerId], references: [id])
  following Profile @relation("followers", fields: [followingId], references: [id])

  status FollowStatus

  respondedAt DateTime?
  createdAt   DateTime  @default(now())
}

enum FriendStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

model Friendship {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  requesterId String       @db.ObjectId
  responderId String       @db.ObjectId
  status      FriendStatus

  respondedAt DateTime?
  createdAt   DateTime  @default(now())

  requester Profile @relation("sentRequests", fields: [requesterId], references: [id])
  responder Profile @relation("receivedRequests", fields: [responderId], references: [id])
}

model Profile {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  displayName      String
  bio              String?
  avatar           String?
  banner           String?
  isPublic         Boolean      @default(true)
  followers        Follow[]     @relation("followers")
  following        Follow[]     @relation("following")
  sentRequests     Friendship[] @relation("sentRequests")
  receivedRequests Friendship[] @relation("receivedRequests")
  links            Link[]
  userId           String       @unique @db.ObjectId

  user User @relation(fields: [userId], references: [id])
}

enum GameStatus {
  PLAYING
  PLATINUM
  COMPLETED
  WISHLIST
  DROPPED
}

type SteamData {
  playtimeForever     Int       @default(0) // minutos
  lastPlayed          DateTime?
  playtime_2weeks     Int       @default(0) // minutos
  achievementsPercent Float     @default(0)
  isPlatinum          Boolean   @default(false)
}

model UserRating {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  story    Int
  gameplay Int
  graphics Int
  sound    Int
  overall  Int

  userGameId String   @unique @db.ObjectId
  userGame   UserGame @relation(fields: [userGameId], references: [id])

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
}

enum GameDifficulty {
  D
  C
  B
  A
  S
  SS
}

enum BeatAction {
  BEAT
  PLATINUM
  COMPLETE
}

model BeatEvents {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userGame   UserGame?  @relation(fields: [userGameId], references: [id])
  userGameId String?    @db.ObjectId
  action     BeatAction
  platformId String     @db.ObjectId
  platform   Platform   @relation(fields: [platformId], references: [id])

  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
}

model UserGame {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  platformIds     String[]   @db.ObjectId
  playedPlatforms Platform[] @relation(fields: [platformIds], references: [id])
  status          GameStatus
  steam           SteamData?
  playtime        Int // em minutos

  beatEvents BeatEvents[]

  rating     UserRating?
  comment    String?
  favorite   Boolean        @default(false)
  difficulty GameDifficulty

  acquiredAt DateTime?

  game   Game?   @relation(fields: [gameId], references: [id])
  gameId String? @db.ObjectId
  user   User?   @relation(fields: [userId], references: [id])
  userId String? @db.ObjectId

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
}

model User {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  email    String? @unique
  username String  @unique
  password String?
  role     Role    @default(USER)

  steamId   String? @unique
  googleId  String? @unique
  discordId String? @unique

  profile Profile?
  library UserGame[]

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
}
